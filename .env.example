PORT=8080
APP_ENV=development
EXTERNAL_BASE_URL=

# Postgres Configuration
DB_USER=
DB_PASSWORD=
DB_NAME=
APP_SYSTEM_PASSWORD=
APP_USER_PASSWORD=

# DB_SOURCE connects to Postgres
DB_SOURCE=

# Goose Migrations
GOOSE_DRIVER=
GOOSE_DBSTRING=
GOOSE_MIGRATION_DIR=cmd/api/migrations
GOOSE_TABLE=goose_db_version

# S3 (Garage Storage Settings)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=garage
S3_ENDPOINT=http://storage.localhost:3900
S3_BUCKET=
CDN_BASE=

# Redis (DragonflyDB is bound to 6379 on the host)
REDIS_URL=redis://localhost:6379/0

# Imgproxy signing credentials (hex encoded)
IMGPROXY_KEY=
IMGPROXY_SALT=

# Bootstrap
PLATFORM_ADMIN_EMAIL=
PLATFORM_ADMIN_PASSWORD=
